# =============================================================
# FLOWYN - Variáveis de Ambiente (exemplo)
# Copie este arquivo para .env.local e preencha os valores
# =============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# --- URL do App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Asaas ---
ASAAS_API_KEY=$aact_sua_chave_aqui
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_SECRET=whsec_seu_secret_aqui
ASAAS_MAIN_WALLET_ID=sua-wallet-id-aqui

# --- Resend (e-mail transacional) ---
RESEND_API_KEY=re_sua_chave_aqui

# --- WhatsApp Webhook ---
WHATSAPP_WEBHOOK_TOKEN=seu-token-aqui
